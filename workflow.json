    {
      "parameters": {
        "jsCode": "const data = $input.first().json[0];\nconst fields = data.fields;\nconst getValue = (fieldName) => fields?.[fieldName]?.value || '';\n\nconst getStoreName = () => {\n  const fieldVal = getValue('storeName');\n  if (fieldVal.match(/[0-9a-f]{2}:[0-9a-f]{2}:[0-9a-f]{2}/i)) {\n    return (data.ocr || '').split('\\n')[0].trim();\n  }\n  return fieldVal;\n};\n\nconst getTotalAmount = () => {\n  const val = getValue('totalAmount');\n  const clean = val.replace(/EUR|[\\n\\r]/g, '').trim().replace(',', '.');\n  return parseFloat(clean) || 0;\n};\n\nconst formatDate = (dateStr) => {\n  if (!dateStr) return '';\n  if (dateStr.includes('.')) {\n    const parts = dateStr.split('.');\n    if (parts.length === 3) return `${parts[2]}-${parts[1]}-${parts[0]}`;\n  }\n  return dateStr;\n};\n\nconst getInvoiceTime = () => {\n  const fieldVal = getValue('invoiceTime');\n  const isValid = fields?.invoiceTime?.isValid !== false;\n  \n  if (isValid && fieldVal && fieldVal.match(/^\\d{2}:\\d{2}/)) {\n    return fieldVal.replace(/Uhr/gi, '').trim();\n  }\n  \n  const ocrText = data.ocr || data.features?.dom?.text || '';\n  const matches = [...ocrText.matchAll(/\\b([01]?[0-9]|2[0-3]):([0-5][0-9])(?::[0-5][0-9])?\\b/g)];\n  \n  if (matches.length > 0) {\n    const fullTime = matches[0][0];\n    const timeParts = fullTime.split(':');\n    return `${timeParts[0]}:${timeParts[1]}`; // فقط HH:MM\n  }\n  \n  return '';\n};\n\nreturn [{\n  json: {\n    storeName:     getStoreName(),\n    invoiceDate:   formatDate(getValue('invoiceDate')),\n    invoiceTime:   getInvoiceTime(),\n    totalAmount:   getTotalAmount(),\n    currency:      'EUR',\n    invoiceNumber: getValue('invoiceNumber')\n  }\n}];"
      },
